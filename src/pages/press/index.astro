---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';

const visible = (e: { data: { draft: boolean } }) =>
  import.meta.env.DEV || !e.data.draft;

const pressKits = (await getCollection('pressKits', visible)).sort((a, b) =>
  a.data.title.localeCompare(b.data.title)
);
---

<BaseLayout title="Press" description="Press kits and assets for Medicated Records.">
  <PageHeader
    eyebrow="For press"
    title="Press Kits"
    description="Bios, photos, and logos for press use."
  />

  <div class="mx-auto max-w-4xl px-5">
    {
      pressKits.length === 0 ? (
        <p class="text-muted">Press kits coming soon.</p>
      ) : (
        <ul class="divide-y divide-line border-y border-line" role="list">
          {pressKits.map((kit) => (
            <li class="py-5">
              <a href={`/press/${kit.id}`} class="group block">
                <h2 class="text-lg font-medium group-hover:underline">
                  {kit.data.title}
                </h2>
                <p class="font-mono text-xs uppercase tracking-widest text-muted">
                  {kit.data.assets.length}{' '}
                  {kit.data.assets.length === 1 ? 'asset' : 'assets'}
                </p>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</BaseLayout>
