---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArtistCredits from '../../components/ArtistCredits.astro';
import { formatDate } from '../../lib/format';

export async function getStaticPaths() {
  const events = await getCollection('events');
  return events.map((event) => ({
    params: { slug: event.id },
    props: { event },
  }));
}

const { event } = Astro.props;
const { Content } = await render(event);
---

<BaseLayout title={event.data.title} description={`${event.data.title} — ${event.data.venue}, ${event.data.city}.`}>
  <article class="mx-auto max-w-4xl px-5 pt-8">
    <Image
      src={event.data.landscapeImage}
      alt={event.data.landscapeImageAlt}
      width={1200}
      height={675}
      widths={[768, 1024, 1200]}
      sizes="(min-width: 896px) 896px, 100vw"
      class="aspect-video w-full bg-surface object-cover"
    />

    <header class="mt-6">
      <p class="eyebrow mb-2">Event</p>
      <h1 class="text-3xl font-medium tracking-tight sm:text-4xl">
        {event.data.title}
      </h1>
      <div class="mt-2">
        <ArtistCredits artists={event.data.artists} />
      </div>
      <p class="mt-3 text-muted">
        {formatDate(event.data.startDate)}
        {event.data.endDate && <> – {formatDate(event.data.endDate)}</>}
        <br />
        {event.data.venue}, {event.data.city}
      </p>

      {
        event.data.ticketUrl && (
          <a
            href={event.data.ticketUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-5 inline-block border border-fg px-4 py-2 font-mono text-xs uppercase tracking-widest transition-colors hover:bg-fg hover:text-bg"
          >
            Tickets ↗
          </a>
        )
      }
    </header>

    <div class="prose-invert mt-8 max-w-prose leading-relaxed text-fg/90">
      <Content />
    </div>
  </article>
</BaseLayout>
