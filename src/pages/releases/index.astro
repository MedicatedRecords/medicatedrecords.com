---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import ArtistCredits from '../../components/ArtistCredits.astro';
import { formatMonthYear } from '../../lib/format';

const visible = (e: { data: { draft: boolean } }) =>
  import.meta.env.DEV || !e.data.draft;

const releases = (await getCollection('releases', visible)).sort(
  (a, b) => b.data.releaseDate.getTime() - a.data.releaseDate.getTime()
);
---

<BaseLayout title="Releases">
  <PageHeader eyebrow="Music" title="Releases" />

  <div class="mx-auto max-w-6xl px-5">
    <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" role="list">
      {
        releases.map((release) => (
          <li>
            <a
              href={`/releases/${release.id}`}
              class="group block focus-visible:outline-none"
            >
              <Image
                src={release.data.squareImage}
                alt={release.data.squareImageAlt}
                width={640}
                height={640}
                widths={[320, 480, 640]}
                sizes="(min-width: 1024px) 33vw, 50vw"
                class="aspect-square w-full bg-surface object-cover transition-transform duration-500 group-hover:scale-105 group-focus-visible:scale-105"
              />
              <h2 class="mt-3 font-medium group-hover:underline group-focus-visible:underline">
                {release.data.title}
              </h2>
            </a>
            <div class="mt-1">
              <ArtistCredits artists={release.data.artists} />
            </div>
            <p class="mt-1 font-mono text-xs uppercase tracking-widest text-muted">
              {formatMonthYear(release.data.releaseDate)}
            </p>
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
