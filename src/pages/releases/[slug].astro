---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArtistCredits from '../../components/ArtistCredits.astro';
import { formatDate } from '../../lib/format';

export async function getStaticPaths() {
  const releases = await getCollection('releases');
  return releases.map((release) => ({
    params: { slug: release.id },
    props: { release },
  }));
}

const { release } = Astro.props;
const { Content } = await render(release);

const linkEntries = Object.entries(release.data.links).filter(([, v]) => v);
---

<BaseLayout title={release.data.title} description={`${release.data.title} — out now on Medicated Records.`}>
  <article class="mx-auto max-w-4xl px-5 pt-8">
    <div class="grid gap-8 sm:grid-cols-[minmax(0,320px)_1fr]">
      <Image
        src={release.data.squareImage}
        alt={release.data.squareImageAlt}
        width={640}
        height={640}
        widths={[320, 480, 640]}
        sizes="(min-width: 640px) 320px, 100vw"
        class="aspect-square w-full bg-surface object-cover"
      />

      <div>
        <p class="eyebrow mb-2">Release</p>
        <h1 class="text-3xl font-medium tracking-tight sm:text-4xl">
          {release.data.title}
        </h1>
        <div class="mt-2">
          <ArtistCredits artists={release.data.artists} />
        </div>
        <p class="mt-2 font-mono text-xs uppercase tracking-widest text-muted">
          {formatDate(release.data.releaseDate)}
          {release.data.catalogNumber && <> · {release.data.catalogNumber}</>}
        </p>

        {
          linkEntries.length > 0 && (
            <ul class="mt-5 flex flex-wrap gap-3 font-mono text-xs uppercase tracking-widest">
              {linkEntries.map(([key, url]) => (
                <li>
                  <a
                    href={url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-block border border-line px-3 py-2 text-muted transition-colors hover:border-fg hover:text-fg"
                  >
                    {key}
                  </a>
                </li>
              ))}
            </ul>
          )
        }
      </div>
    </div>

    {
      release.data.tracklist && release.data.tracklist.length > 0 && (
        <section class="mt-12">
          <h2 class="mb-3 font-mono text-xs uppercase tracking-widest text-muted">
            Tracklist
          </h2>
          <ol class="space-y-1">
            {release.data.tracklist.map((track, i) => (
              <li class="flex gap-3">
                <span class="font-mono text-muted">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <span>{track}</span>
              </li>
            ))}
          </ol>
        </section>
      )
    }

    <div class="prose-invert mt-10 max-w-prose leading-relaxed text-fg/90">
      <Content />
    </div>
  </article>
</BaseLayout>
