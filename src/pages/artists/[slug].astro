---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getArtistRelated } from '../../lib/related';
import { formatDate } from '../../lib/format';

export async function getStaticPaths() {
  const artists = await getCollection('artists');
  return artists.map((artist) => ({
    params: { slug: artist.id },
    props: { artist },
  }));
}

const { artist } = Astro.props;
const { Content } = await render(artist);
const related = await getArtistRelated(artist.id);

const linkEntries = Object.entries(artist.data.links).filter(([, v]) => v);
---

<BaseLayout title={artist.data.name} description={`${artist.data.name} on Medicated Records.`}>
  <article class="mx-auto max-w-4xl px-5 pt-8">
    <Image
      src={artist.data.landscapeImage}
      alt={artist.data.landscapeImageAlt}
      width={1200}
      height={675}
      widths={[768, 1024, 1200]}
      sizes="(min-width: 896px) 896px, 100vw"
      class="aspect-video w-full bg-surface object-cover"
    />

    <header class="mt-6">
      <p class="eyebrow mb-2">Artist</p>
      <h1 class="text-3xl font-medium tracking-tight sm:text-4xl">
        {artist.data.name}
      </h1>
    </header>

    {
      linkEntries.length > 0 && (
        <ul class="mt-4 flex flex-wrap gap-x-5 gap-y-2 font-mono text-xs uppercase tracking-widest">
          {linkEntries.map(([key, url]) => (
            <li>
              <a
                href={url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-muted underline-offset-4 hover:text-fg hover:underline"
              >
                {key}
              </a>
            </li>
          ))}
        </ul>
      )
    }

    <div class="prose-invert mt-8 max-w-prose leading-relaxed text-fg/90">
      <Content />
    </div>

    {
      related.releases.length > 0 && (
        <section class="mt-12">
          <h2 class="mb-3 font-mono text-xs uppercase tracking-widest text-muted">
            Releases
          </h2>
          <ul class="space-y-1" role="list">
            {related.releases.map((r) => (
              <li>
                <a href={`/releases/${r.id}`} class="hover:underline">
                  {r.data.title}
                  <span class="text-muted"> — {formatDate(r.data.releaseDate)}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      related.mixes.length > 0 && (
        <section class="mt-10">
          <h2 class="mb-3 font-mono text-xs uppercase tracking-widest text-muted">
            Mixes
          </h2>
          <ul class="space-y-1" role="list">
            {related.mixes.map((m) => (
              <li>
                <a href={`/mixes/${m.id}`} class="hover:underline">
                  {m.data.title}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      related.events.length > 0 && (
        <section class="mt-10">
          <h2 class="mb-3 font-mono text-xs uppercase tracking-widest text-muted">
            Events
          </h2>
          <ul class="space-y-1" role="list">
            {related.events.map((e) => (
              <li>
                <a href={`/events/${e.id}`} class="hover:underline">
                  {e.data.title}
                  <span class="text-muted"> — {e.data.city}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </article>
</BaseLayout>
