---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';

const visible = (e: { data: { draft: boolean } }) =>
  import.meta.env.DEV || !e.data.draft;

const artists = (await getCollection('artists', visible)).sort((a, b) =>
  a.data.name.localeCompare(b.data.name)
);
---

<BaseLayout title="Artists">
  <PageHeader eyebrow="Roster" title="Artists" />

  <div class="mx-auto max-w-6xl px-5">
    <ul class="grid gap-6 sm:grid-cols-2" role="list">
      {
        artists.map((artist) => (
          <li>
            <a
              href={`/artists/${artist.id}`}
              class="group block overflow-hidden bg-surface focus-visible:outline-none"
            >
              <Image
                src={artist.data.landscapeImage}
                alt={artist.data.landscapeImageAlt}
                width={800}
                height={450}
                widths={[480, 768, 800]}
                sizes="(min-width: 768px) 50vw, 100vw"
                class="aspect-video w-full object-cover transition-transform duration-500 group-hover:scale-105 group-focus-visible:scale-105"
              />
              <div class="p-4">
                <h2 class="text-lg font-medium group-hover:underline group-focus-visible:underline">
                  {artist.data.name}
                </h2>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
