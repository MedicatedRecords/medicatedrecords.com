---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { formatDate } from '../../lib/format';

const visible = (e: { data: { draft: boolean } }) =>
  import.meta.env.DEV || !e.data.draft;

const posts = (await getCollection('posts', visible)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<BaseLayout title="News">
  <PageHeader eyebrow="Label" title="News" />

  <div class="mx-auto max-w-4xl px-5">
    {
      posts.length === 0 ? (
        <p class="text-muted">No news yet.</p>
      ) : (
        <ul class="grid gap-6 sm:grid-cols-2" role="list">
          {posts.map((post) => (
            <li>
              <a
                href={`/news/${post.id}`}
                class="group block focus-visible:outline-none"
              >
                <Image
                  src={post.data.landscapeImage}
                  alt={post.data.landscapeImageAlt}
                  width={800}
                  height={450}
                  widths={[480, 768, 800]}
                  sizes="(min-width: 768px) 50vw, 100vw"
                  class="aspect-video w-full bg-surface object-cover transition-transform duration-500 group-hover:scale-105 group-focus-visible:scale-105"
                />
                <p class="mt-3 font-mono text-xs uppercase tracking-widest text-muted">
                  {formatDate(post.data.date)}
                </p>
                <h2 class="mt-1 font-medium group-hover:underline group-focus-visible:underline">
                  {post.data.title}
                </h2>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</BaseLayout>
