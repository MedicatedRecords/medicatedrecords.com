---
interface Props {
  title: string;
  eyebrow?: string;
  description?: string;
}

const { title, eyebrow, description } = Astro.props;
---

<div class="mx-auto max-w-6xl px-5 pb-8 pt-12">
  {eyebrow && <p class="eyebrow mb-3">{eyebrow}</p>}
  <h1 class="text-3xl font-medium tracking-tight sm:text-4xl">{title}</h1>
  {
    description && (
      <p class="mt-3 max-w-prose text-muted">{description}</p>
    )
  }
</div>
