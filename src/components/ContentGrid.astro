---
import Tile from './Tile.astro';
import type { FeedItem } from '../lib/feed';

interface Props {
  items: FeedItem[];
}

const { items } = Astro.props;
---

<ul
  class="grid grid-cols-2 gap-x-4 gap-y-8 sm:grid-cols-3 lg:grid-cols-4"
  role="list"
>
  {
    items.map((item) => (
      <li>
        <Tile item={item} />
      </li>
    ))
  }
</ul>
