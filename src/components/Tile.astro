---
import { Image } from 'astro:assets';
import type { FeedItem } from '../lib/feed';

interface Props {
  item: FeedItem;
}

const { item } = Astro.props;
---

<a
  href={item.href}
  class="group block focus-visible:outline-none"
  aria-label={`${item.typeLabel}: ${item.title}`}
>
  <div class="relative overflow-hidden bg-surface">
    <Image
      src={item.squareImage}
      alt={item.squareImageAlt}
      width={640}
      height={640}
      widths={[320, 480, 640]}
      sizes="(min-width: 1024px) 25vw, (min-width: 640px) 33vw, 50vw"
      class="aspect-square w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105 group-focus-visible:scale-105"
    />
    <span
      class="absolute left-2 top-2 bg-bg/80 px-2 py-1 font-mono text-[0.6rem] uppercase tracking-widest text-fg backdrop-blur-sm"
    >
      {item.typeLabel}
    </span>
  </div>
  <h3 class="mt-2 text-sm font-medium leading-snug">
    <span class="underline-offset-2 group-hover:underline group-focus-visible:underline">
      {item.title}
    </span>
  </h3>
</a>
