---
import { getArtistCredits } from '../lib/related';

interface Props {
  artists: { collection: 'artists'; id: string }[];
}

const { artists } = Astro.props;
const credits = await getArtistCredits(artists);
---

<p class="font-mono text-sm text-muted">
  {
    credits.map((artist, i) => (
      <>
        {i > 0 && <span aria-hidden="true">, </span>}
        <a href={`/artists/${artist.id}`} class="hover:text-fg hover:underline">
          {artist.name}
        </a>
      </>
    ))
  }
</p>
